<% layout('layout/main') %>
<!-- Header -->
<div class="page-header">
  <div>
    <h1>📝 Tạo Phiếu Mượn Sách</h1>
    <p>Chọn độc giả và sách cần mượn</p>
  </div>
  <a href="/borrows" class="btn btn-ghost">← Quay lại</a>
</div>

<div class="card" style="max-width: 800px">
  <div class="card-header">
    <span class="card-title">📋 Thông tin phiếu mượn</span>
  </div>
  <div class="card-body">
    <% if (errors && errors.length > 0) { %>
      <div class="error-list">
        <ul><% errors.forEach(e => { %><li><%= e %></li><% }) %></ul>
      </div>
    <% } %>

    <form action="/borrows" method="POST">
      <div class="form-grid">
        <!-- Độc giả -->
        <div class="form-group">
          <label class="form-label" for="reader_id">Độc giả <span class="required">*</span></label>
          <select id="reader_id" name="reader_id" class="form-control" required>
            <option value="">-- Chọn độc giả --</option>
            <% readers.forEach(r => { %>
              <option value="<%= r.id %>" <%= (borrow.reader_id == r.id) ? 'selected' : '' %>>
                <%= r.member_id %> - <%= r.name %>
              </option>
            <% }) %>
          </select>
        </div>

        <!-- Sách -->
        <div class="form-group">
          <label class="form-label" for="book_id">Sách mượn <span class="required">*</span></label>
          <select id="book_id" name="book_id" class="form-control" required>
            <option value="">-- Chọn sách --</option>
            <% books.forEach(b => { %>
              <option value="<%= b.id %>"
                <%= (borrow.book_id == b.id) ? 'selected' : '' %>
                <%= b.available === 0 ? 'disabled style="color:var(--danger)"' : '' %>>
                <%= b.title %> - <%= b.author %>
                (<%= b.available === 0 ? 'HẾT SÁCH' : `Còn ${b.available}` %>)
              </option>
            <% }) %>
          </select>
          <span class="form-hint">🔴 Sách bị disabled = đã hết, không thể mượn</span>
        </div>

        <!-- Ngày mượn -->
        <div class="form-group">
          <label class="form-label" for="borrow_date">Ngày mượn <span class="required">*</span></label>
          <input type="date" id="borrow_date" name="borrow_date" class="form-control"
            value="<%= borrow.borrow_date || today %>" required>
        </div>

        <!-- Ngày hạn trả -->
        <div class="form-group">
          <label class="form-label" for="due_date">Ngày hạn trả <span class="required">*</span></label>
          <input type="date" id="due_date" name="due_date" class="form-control"
            value="<%= borrow.due_date || defaultDue %>" required>
          <span class="form-hint">Mặc định 14 ngày. Tự động cập nhật khi đổi ngày mượn.</span>
        </div>

        <!-- Ghi chú -->
        <div class="form-group full-width">
          <label class="form-label" for="note">Ghi chú</label>
          <textarea id="note" name="note" class="form-control" placeholder="Ghi chú thêm về tình trạng sách, yêu cầu đặc biệt..."><%= borrow.note || '' %></textarea>
        </div>
      </div>

      <!-- Info Box -->
      <div style="background:rgba(99,102,241,0.08); border:1px solid rgba(99,102,241,0.2); border-radius:var(--radius-sm); padding:14px; margin-top:16px; font-size:0.85rem; color:var(--text-muted)">
        💡 <strong>Lưu ý:</strong> Tiền phạt sẽ được tính <strong>2,000 VNĐ/ngày/quyển</strong> nếu trả trễ hạn.
      </div>

      <div style="display:flex; gap:12px; margin-top:24px; padding-top:20px; border-top:1px solid var(--border)">
        <button type="submit" class="btn btn-primary">✅ Tạo phiếu mượn</button>
        <a href="/borrows" class="btn btn-ghost">Hủy</a>
      </div>
    </form>
  </div>
</div>
