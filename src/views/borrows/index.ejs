<% layout('layout/main') %>
<!-- Header -->
<div class="page-header">
  <div>
    <h1>📋 Quản lý Mượn / Trả</h1>
    <p>Tổng cộng <strong><%= total %></strong> phiếu mượn</p>
  </div>
  <a href="/borrows/new" class="btn btn-primary">📝 Tạo phiếu mượn</a>
</div>

<!-- Filter -->
<div class="card mb-4">
  <div class="card-body">
    <form action="/borrows" method="GET">
      <div class="search-bar">
        <div class="search-input-wrap" style="flex:1">
          <span class="search-icon">🔍</span>
          <input type="text" name="search" value="<%= search %>" placeholder="Tìm tên độc giả, mã TV, tên sách..." class="form-control">
        </div>
        <select name="status" class="form-control" id="status-filter" style="max-width:180px">
          <option value="">-- Tất cả trạng thái --</option>
          <option value="borrowing" <%= status === 'borrowing' ? 'selected' : '' %>>📖 Đang mượn</option>
          <option value="returned" <%= status === 'returned' ? 'selected' : '' %>>✅ Đã trả</option>
        </select>
        <button type="submit" class="btn btn-primary">Tìm</button>
        <% if (search || status) { %>
          <a href="/borrows" class="btn btn-ghost">✕ Xóa lọc</a>
        <% } %>
      </div>
    </form>
  </div>
</div>

<!-- Table -->
<div class="card">
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Độc giả</th>
          <th>Sách mượn</th>
          <th>Ngày mượn</th>
          <th>Ngày hạn</th>
          <th>Tiền phạt</th>
          <th>Trạng thái</th>
          <th style="text-align:center">Thao tác</th>
        </tr>
      </thead>
      <tbody>
        <% if (borrows.length === 0) { %>
          <tr>
            <td colspan="8">
              <div class="empty-state">
                <div class="empty-icon">📭</div>
                <h3>Không có phiếu mượn nào</h3>
                <p><% if (search || status) { %>Thử thay đổi bộ lọc<% } else { %>Tạo phiếu mượn đầu tiên<% } %></p>
                <a href="/borrows/new" class="btn btn-primary">📝 Tạo phiếu mượn</a>
              </div>
            </td>
          </tr>
        <% } else { %>
          <% borrows.forEach(b => { %>
            <tr>
              <td style="color:var(--text-faint); font-size:0.8rem"><a href="/borrows/<%= b.id %>" style="color:var(--primary-light); font-weight:700">#<%= b.id %></a></td>
              <td>
                <div style="font-weight:600"><%= b.reader_name %></div>
                <div style="font-size:0.75rem; color:var(--text-muted)"><%= b.member_id %></div>
              </td>
              <td>
                <div style="font-weight:500; max-width:180px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap"><%= b.book_title %></div>
                <div style="font-size:0.75rem; color:var(--text-muted)"><%= b.book_author %></div>
              </td>
              <td style="font-size:0.82rem"><%= b.borrow_date %></td>
              <td style="font-size:0.82rem">
                <%= b.due_date %>
                <% if (b.is_overdue) { %>
                  <div style="font-size:0.72rem; color:#f87171">⏰ Đã quá hạn</div>
                <% } %>
              </td>
              <td>
                <% const fine = b.status === 'borrowing' ? b.current_fine : b.fine_amount; %>
                <% if (fine > 0) { %>
                  <span style="color:#f87171; font-weight:600"><%= fine.toLocaleString('vi-VN') %>₫</span>
                <% } else { %>
                  <span style="color:var(--text-faint)">—</span>
                <% } %>
              </td>
              <td>
                <% if (b.status === 'returned') { %>
                  <span class="badge badge-success">✅ Đã trả</span>
                <% } else if (b.is_overdue) { %>
                  <span class="badge badge-danger">🔴 Quá hạn</span>
                <% } else { %>
                  <span class="badge badge-info">📖 Đang mượn</span>
                <% } %>
              </td>
              <td style="text-align:center">
                <div style="display:flex; gap:6px; justify-content:center">
                  <a href="/borrows/<%= b.id %>" class="btn btn-ghost btn-sm btn-icon" title="Xem">👁️</a>
                  <% if (b.status === 'borrowing') { %>
                    <form action="/borrows/<%= b.id %>/return" method="POST" style="display:inline">
                      <button type="submit" class="btn btn-success btn-sm"
                        data-confirm="Xác nhận trả sách '#<%= b.book_title %>'?">
                        ✅ Trả sách
                      </button>
                    </form>
                  <% } %>
                </div>
              </td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>

  <% if (totalPages > 1) { %>
    <div class="pagination">
      <a href="/borrows?search=<%= search %>&status=<%= status %>&page=<%= Math.max(1, page-1) %>" class="page-btn <%= page <= 1 ? 'disabled' : '' %>">‹</a>
      <% for(let i = 1; i <= totalPages; i++) { %>
        <a href="/borrows?search=<%= search %>&status=<%= status %>&page=<%= i %>" class="page-btn <%= i === page ? 'active' : '' %>"><%= i %></a>
      <% } %>
      <a href="/borrows?search=<%= search %>&status=<%= status %>&page=<%= Math.min(totalPages, page+1) %>" class="page-btn <%= page >= totalPages ? 'disabled' : '' %>">›</a>
    </div>
  <% } %>
</div>
