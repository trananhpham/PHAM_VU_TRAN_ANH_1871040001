<% layout('layout/main') %>
<!-- Stats Grid -->
<div class="stats-grid">
  <div class="stat-card" style="--accent-color: #6366f1; --icon-bg: rgba(99,102,241,0.15)">
    <div class="stat-icon">📚</div>
    <div class="stat-info">
      <div class="stat-value"><%= stats.totalBooks %></div>
      <div class="stat-label">Tổng số đầu sách</div>
    </div>
  </div>
  <div class="stat-card" style="--accent-color: #0ea5e9; --icon-bg: rgba(14,165,233,0.15)">
    <div class="stat-icon">👥</div>
    <div class="stat-info">
      <div class="stat-value"><%= stats.totalReaders %></div>
      <div class="stat-label">Độc giả đăng ký</div>
    </div>
  </div>
  <div class="stat-card" style="--accent-color: #10b981; --icon-bg: rgba(16,185,129,0.15)">
    <div class="stat-icon">📖</div>
    <div class="stat-info">
      <div class="stat-value"><%= stats.activeBorrows %></div>
      <div class="stat-label">Đang mượn</div>
    </div>
  </div>
  <div class="stat-card" style="--accent-color: #ef4444; --icon-bg: rgba(239,68,68,0.15)">
    <div class="stat-icon">⚠️</div>
    <div class="stat-info">
      <div class="stat-value"><%= stats.overdue %></div>
      <div class="stat-label">Quá hạn</div>
    </div>
  </div>
  <div class="stat-card" style="--accent-color: #f59e0b; --icon-bg: rgba(245,158,11,0.15)">
    <div class="stat-icon">💰</div>
    <div class="stat-info">
      <div class="stat-value"><%= stats.totalFine.toLocaleString('vi-VN') %>₫</div>
      <div class="stat-label">Tổng tiền phạt</div>
    </div>
  </div>
  <div class="stat-card" style="--accent-color: #06b6d4; --icon-bg: rgba(6,182,212,0.15)">
    <div class="stat-icon">✅</div>
    <div class="stat-info">
      <div class="stat-value"><%= stats.returnedToday %></div>
      <div class="stat-label">Trả sách hôm nay</div>
    </div>
  </div>
</div>

<!-- Dashboard Grid -->
<div class="dashboard-grid">
  <!-- Recent Borrows -->
  <div class="card">
    <div class="card-header">
      <span class="card-title">📋 Phiếu mượn gần đây</span>
      <a href="/borrows" class="btn btn-ghost btn-sm">Xem tất cả →</a>
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>#</th>
            <th>Độc giả</th>
            <th>Sách</th>
            <th>Ngày hạn</th>
            <th>Trạng thái</th>
          </tr>
        </thead>
        <tbody>
          <% if (recentBorrows.length === 0) { %>
            <tr><td colspan="5" style="text-align:center; color: var(--text-faint); padding: 30px">Chưa có phiếu mượn nào</td></tr>
          <% } else { %>
            <% recentBorrows.forEach(b => { %>
              <tr>
                <td><a href="/borrows/<%= b.id %>" style="color: var(--primary-light); font-weight:600">#<%= b.id %></a></td>
                <td>
                  <div style="font-weight:500"><%= b.reader_name %></div>
                  <div style="font-size:0.75rem; color:var(--text-muted)"><%= b.member_id %></div>
                </td>
                <td class="truncate"><%= b.book_title %></td>
                <td style="font-size:0.82rem"><%= b.due_date %></td>
                <td>
                  <% if (b.status === 'returned') { %>
                    <span class="badge badge-success">✅ Đã trả</span>
                  <% } else if (b.is_overdue) { %>
                    <span class="badge badge-danger">🔴 Quá hạn</span>
                  <% } else { %>
                    <span class="badge badge-info">📖 Đang mượn</span>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Top Books -->
  <div class="card">
    <div class="card-header">
      <span class="card-title">🔥 Sách mượn nhiều nhất</span>
    </div>
    <div class="card-body">
      <% if (topBooks.length === 0) { %>
        <p style="text-align:center; color:var(--text-faint); padding:20px">Chưa có dữ liệu</p>
      <% } else { %>
        <% topBooks.forEach((book, i) => { %>
          <div style="display:flex; align-items:center; gap:12px; padding:10px 0; border-bottom: 1px solid var(--border);">
            <div style="width:28px; height:28px; border-radius:8px; background: linear-gradient(135deg, var(--primary), var(--secondary)); display:flex; align-items:center; justify-content:center; font-weight:800; font-size:0.8rem; flex-shrink:0"><%= i+1 %></div>
            <div style="flex:1; min-width:0">
              <div style="font-weight:600; font-size:0.85rem; overflow:hidden; text-overflow:ellipsis; white-space:nowrap"><%= book.title %></div>
              <div style="font-size:0.75rem; color:var(--text-muted)"><%= book.author %></div>
            </div>
            <span class="badge badge-primary"><%= book.borrow_count %> lần</span>
          </div>
        <% }) %>
      <% } %>
    </div>
  </div>
</div>

<!-- Quick Actions -->
<div style="display:flex; gap:12px; margin-top:20px; flex-wrap:wrap">
  <a href="/books/new" class="btn btn-primary">➕ Thêm sách mới</a>
  <a href="/readers/new" class="btn btn-success">👤 Đăng ký độc giả</a>
  <a href="/borrows/new" class="btn btn-warning">📝 Tạo phiếu mượn</a>
  <a href="/borrows?status=borrowing" class="btn btn-ghost">📋 Xem đang mượn</a>
</div>
