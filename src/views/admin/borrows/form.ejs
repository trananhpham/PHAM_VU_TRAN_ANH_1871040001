<% layout('layout/admin') %>

<div class="admin-page-header">
  <div><h1>📝 Tạo Phiếu Mượn Sách</h1><p>Chọn độc giả và sách cần mượn</p></div>
  <a href="/admin/borrows" class="btn btn-ghost">← Quay lại</a>
</div>

<div class="admin-card" style="max-width:760px">
  <div class="admin-card-header"><span class="admin-card-title">📋 Thông tin phiếu mượn</span></div>
  <div class="admin-card-body">
    <% if (errors && errors.length > 0) { %>
      <div class="admin-errors"><ul><% errors.forEach(e => { %><li><%= e %></li><% }) %></ul></div>
    <% } %>
    <form action="/admin/borrows" method="POST">
      <div class="admin-form-grid">
        <div class="admin-form-group">
          <label class="admin-form-label" for="reader_id">Độc giả <span class="req">*</span></label>
          <select id="reader_id" name="reader_id" class="admin-form-control" required>
            <option value="">-- Chọn độc giả --</option>
            <% readers.forEach(r => { %>
              <option value="<%= r.id %>" <%= borrow.reader_id == r.id ? 'selected' : '' %>><%= r.member_id %> — <%= r.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="admin-form-group">
          <label class="admin-form-label" for="book_id">Sách mượn <span class="req">*</span></label>
          <select id="book_id" name="book_id" class="admin-form-control" required>
            <option value="">-- Chọn sách --</option>
            <% books.forEach(b => { %>
              <option value="<%= b.id %>" <%= borrow.book_id == b.id ? 'selected' : '' %> <%= b.available === 0 ? 'disabled' : '' %>>
                <%= b.title %> (<%= b.available === 0 ? 'HẾT SÁCH' : `Còn ${b.available}` %>)
              </option>
            <% }) %>
          </select>
          <span class="admin-form-hint">Sách bị disabled = đã hết, không thể mượn</span>
        </div>
        <div class="admin-form-group">
          <label class="admin-form-label" for="borrow_date">Ngày mượn <span class="req">*</span></label>
          <input type="date" id="borrow_date" name="borrow_date" class="admin-form-control" value="<%= borrow.borrow_date || today %>" required>
        </div>
        <div class="admin-form-group">
          <label class="admin-form-label" for="due_date">Ngày hạn trả <span class="req">*</span></label>
          <input type="date" id="due_date" name="due_date" class="admin-form-control" value="<%= borrow.due_date || defaultDue %>" required>
          <span class="admin-form-hint">Mặc định 14 ngày. Tự cập nhật khi đổi ngày mượn.</span>
        </div>
        <div class="admin-form-group full">
          <label class="admin-form-label" for="note">Ghi chú</label>
          <textarea id="note" name="note" class="admin-form-control" placeholder="Ghi chú thêm..."><%= borrow.note || '' %></textarea>
        </div>
      </div>
      <div style="background:rgba(99,102,241,0.07); border:1px solid rgba(99,102,241,0.15); border-radius:var(--a-radius-sm); padding:12px; margin-top:14px; font-size:0.78rem; color:var(--a-muted)">
        💡 Tiền phạt: <strong>2,000 VNĐ/ngày/quyển</strong> nếu trả trễ hạn.
      </div>
      <div style="display:flex; gap:10px; margin-top:20px; padding-top:16px; border-top:1px solid var(--a-border)">
        <button type="submit" class="btn btn-primary">✅ Tạo phiếu mượn</button>
        <a href="/admin/borrows" class="btn btn-ghost">Hủy</a>
      </div>
    </form>
  </div>
</div>
