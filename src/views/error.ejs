<% layout('layout/main') %>
<!-- Error Page -->
<div style="display:flex; align-items:center; justify-content:center; min-height:60vh">
  <div style="text-align:center; max-width:400px">
    <div style="font-size:4rem; margin-bottom:16px">⚠️</div>
    <h2 style="font-size:1.3rem; font-weight:700; margin-bottom:8px; color:var(--danger)">Đã xảy ra lỗi</h2>
    <p style="color:var(--text-muted); margin-bottom:24px; font-size:0.9rem"><%= message || 'Có lỗi không xác định xảy ra.' %></p>
    <div style="display:flex; gap:10px; justify-content:center">
      <a href="/" class="btn btn-primary">🏠 Về trang chủ</a>
      <a href="javascript:history.back()" class="btn btn-ghost">← Quay lại</a>
    </div>
  </div>
</div>
