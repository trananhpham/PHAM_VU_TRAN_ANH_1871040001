<% layout('layout/main') %>
<!-- Header -->
<div class="page-header">
  <div>
    <h1>👥 Quản lý Độc giả</h1>
    <p>Tổng cộng <strong><%= total %></strong> độc giả đã đăng ký</p>
  </div>
  <a href="/readers/new" class="btn btn-primary">👤 Đăng ký Độc giả</a>
</div>

<!-- Search -->
<div class="card mb-4">
  <div class="card-body">
    <form action="/readers" method="GET">
      <div class="search-bar">
        <div class="search-input-wrap" style="flex:1">
          <span class="search-icon">🔍</span>
          <input type="text" name="search" value="<%= search %>" placeholder="Tìm tên, email, mã thành viên, SĐT..." class="form-control">
        </div>
        <button type="submit" class="btn btn-primary">Tìm kiếm</button>
        <% if (search) { %>
          <a href="/readers" class="btn btn-ghost">✕ Xóa lọc</a>
        <% } %>
      </div>
    </form>
  </div>
</div>

<!-- Table -->
<div class="card">
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Mã TV</th>
          <th>Họ tên</th>
          <th>Email</th>
          <th>SĐT</th>
          <th>Địa chỉ</th>
          <th>Ngày đăng ký</th>
          <th style="text-align:center">Thao tác</th>
        </tr>
      </thead>
      <tbody>
        <% if (readers.length === 0) { %>
          <tr>
            <td colspan="7">
              <div class="empty-state">
                <div class="empty-icon">👤</div>
                <h3>Không tìm thấy độc giả</h3>
                <p><% if (search) { %>Thử tìm với từ khóa khác<% } else { %>Hãy đăng ký độc giả đầu tiên<% } %></p>
                <a href="/readers/new" class="btn btn-primary">👤 Đăng ký ngay</a>
              </div>
            </td>
          </tr>
        <% } else { %>
          <% readers.forEach(reader => { %>
            <tr>
              <td><span class="badge badge-primary"><%= reader.member_id %></span></td>
              <td>
                <a href="/readers/<%= reader.id %>" style="font-weight:600; color:var(--text)">
                  <%= reader.name %>
                </a>
              </td>
              <td style="color:var(--text-muted); font-size:0.85rem"><%= reader.email %></td>
              <td style="color:var(--text-muted); font-size:0.85rem"><%= reader.phone || '—' %></td>
              <td style="color:var(--text-muted); font-size:0.82rem" class="truncate"><%= reader.address || '—' %></td>
              <td style="font-size:0.8rem; color:var(--text-faint)"><%= reader.created_at.split(' ')[0] %></td>
              <td>
                <div style="display:flex; gap:6px; justify-content:center">
                  <a href="/readers/<%= reader.id %>" class="btn btn-ghost btn-sm btn-icon" title="Xem">👁️</a>
                  <a href="/readers/<%= reader.id %>/edit" class="btn btn-ghost btn-sm btn-icon" title="Sửa">✏️</a>
                  <form action="/readers/<%= reader.id %>?_method=DELETE" method="POST" style="display:inline">
                    <input type="hidden" name="_method" value="DELETE">
                    <button type="submit" class="btn btn-danger btn-sm btn-icon"
                      data-confirm="Xóa độc giả '<%= reader.name %>'?">🗑️</button>
                  </form>
                </div>
              </td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>

  <% if (totalPages > 1) { %>
    <div class="pagination">
      <a href="/readers?search=<%= search %>&page=<%= Math.max(1, page-1) %>" class="page-btn <%= page <= 1 ? 'disabled' : '' %>">‹</a>
      <% for(let i = 1; i <= totalPages; i++) { %>
        <a href="/readers?search=<%= search %>&page=<%= i %>" class="page-btn <%= i === page ? 'active' : '' %>"><%= i %></a>
      <% } %>
      <a href="/readers?search=<%= search %>&page=<%= Math.min(totalPages, page+1) %>" class="page-btn <%= page >= totalPages ? 'disabled' : '' %>">›</a>
    </div>
  <% } %>
</div>
