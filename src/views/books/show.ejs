<% layout('layout/main') %>
<!-- Header -->
<div class="page-header">
  <div>
    <h1>📖 <%= book.title %></h1>
    <p>Chi tiết thông tin sách</p>
  </div>
  <div style="display:flex; gap:10px">
    <a href="/books/<%= book.id %>/edit" class="btn btn-primary">✏️ Sửa</a>
    <a href="/books" class="btn btn-ghost">← Danh sách</a>
  </div>
</div>

<div style="display:grid; grid-template-columns: 1fr 1fr; gap:20px; max-width: 900px">
  <!-- Thông tin sách -->
  <div class="card" style="grid-column: 1 / -1">
    <div class="card-header">
      <span class="card-title">📚 Thông tin chi tiết</span>
      <span class="badge badge-info"><%= book.category %></span>
    </div>
    <div class="card-body">
      <div class="detail-grid" style="grid-template-columns: repeat(3, 1fr)">
        <div class="detail-item">
          <div class="detail-label">Tác giả</div>
          <div class="detail-value"><%= book.author %></div>
        </div>
        <div class="detail-item">
          <div class="detail-label">ISBN</div>
          <div class="detail-value"><%= book.isbn || '—' %></div>
        </div>
        <div class="detail-item">
          <div class="detail-label">Năm xuất bản</div>
          <div class="detail-value"><%= book.published_year || '—' %></div>
        </div>
        <div class="detail-item">
          <div class="detail-label">Tổng số lượng</div>
          <div class="detail-value" style="font-size:1.2rem; font-weight:800"><%= book.quantity %></div>
        </div>
        <div class="detail-item">
          <div class="detail-label">Có thể mượn</div>
          <div class="detail-value">
            <span class="available-count <%= book.available === 0 ? 'zero' : book.available <= 2 ? 'low' : 'ok' %>" style="font-size:1.2rem">
              <%= book.available === 0 ? '🔴' : book.available <= 2 ? '🟡' : '🟢' %>
              <%= book.available %>
            </span>
          </div>
        </div>
        <div class="detail-item">
          <div class="detail-label">Ngày thêm</div>
          <div class="detail-value" style="font-size:0.85rem"><%= book.created_at %></div>
        </div>
        <% if (book.description) { %>
          <div class="detail-item" style="grid-column: 1 / -1">
            <div class="detail-label">Mô tả</div>
            <div class="detail-value" style="line-height:1.6; color:var(--text-muted)"><%= book.description %></div>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<div style="display:flex; gap:12px; margin-top:16px">
  <a href="/borrows/new?book_id=<%= book.id %>" class="btn btn-success">📝 Tạo phiếu mượn</a>
  <form action="/books/<%= book.id %>?_method=DELETE" method="POST" style="display:inline">
    <input type="hidden" name="_method" value="DELETE">
    <button type="submit" class="btn btn-danger"
      data-confirm="Bạn có chắc muốn xóa sách '<%= book.title %>'?">
      🗑️ Xóa sách
    </button>
  </form>
</div>
