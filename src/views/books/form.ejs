<% layout('layout/main') %>
<!-- Header -->
<div class="page-header">
  <div>
    <h1><%= isEdit ? '✏️ Sửa Sách' : '➕ Thêm Sách Mới' %></h1>
    <p><%= isEdit ? `Đang sửa: ${book.title}` : 'Điền thông tin sách vào form bên dưới' %></p>
  </div>
  <a href="/books" class="btn btn-ghost">← Quay lại</a>
</div>

<div class="card" style="max-width: 900px">
  <div class="card-header">
    <span class="card-title"><%= isEdit ? '📝 Cập nhật thông tin sách' : '📚 Thông tin sách' %></span>
  </div>
  <div class="card-body">
    <!-- Errors -->
    <% if (errors && errors.length > 0) { %>
      <div class="error-list">
        <ul>
          <% errors.forEach(e => { %><li><%= e %></li><% }) %>
        </ul>
      </div>
    <% } %>

    <form action="<%= isEdit ? `/books/${book.id}?_method=PUT` : '/books' %>" method="POST">
      <% if (isEdit) { %>
        <input type="hidden" name="_method" value="PUT">
      <% } %>

      <div class="form-grid">
        <!-- Tên sách -->
        <div class="form-group full-width">
          <label class="form-label" for="title">Tên sách <span class="required">*</span></label>
          <input type="text" id="title" name="title" class="form-control"
            value="<%= book.title || '' %>" placeholder="Nhập tên sách..." required>
        </div>

        <!-- Tác giả -->
        <div class="form-group">
          <label class="form-label" for="author">Tác giả <span class="required">*</span></label>
          <input type="text" id="author" name="author" class="form-control"
            value="<%= book.author || '' %>" placeholder="Nhập tên tác giả..." required>
        </div>

        <!-- Thể loại -->
        <div class="form-group">
          <label class="form-label" for="category">Thể loại <span class="required">*</span></label>
          <input type="text" id="category" name="category" class="form-control"
            value="<%= book.category || '' %>"
            placeholder="Vd: Lập trình, Văn học, Khoa học..."
            list="category-list" required>
          <datalist id="category-list">
            <% categories.forEach(cat => { %>
              <option value="<%= cat %>">
            <% }) %>
          </datalist>
        </div>

        <!-- ISBN -->
        <div class="form-group">
          <label class="form-label" for="isbn">ISBN</label>
          <input type="text" id="isbn" name="isbn" class="form-control"
            value="<%= book.isbn || '' %>" placeholder="Nhập mã ISBN...">
          <span class="form-hint">Mã định danh sách (không bắt buộc)</span>
        </div>

        <!-- Số lượng -->
        <div class="form-group">
          <label class="form-label" for="quantity">Số lượng <span class="required">*</span></label>
          <input type="number" id="quantity" name="quantity" class="form-control"
            value="<%= book.quantity || 1 %>" min="1" max="999" required>
        </div>

        <!-- Năm xuất bản -->
        <div class="form-group">
          <label class="form-label" for="published_year">Năm xuất bản</label>
          <input type="number" id="published_year" name="published_year" class="form-control"
            value="<%= book.published_year || '' %>" min="1900" max="<%= new Date().getFullYear() %>"
            placeholder="Vd: 2023">
        </div>

        <!-- Mô tả -->
        <div class="form-group full-width">
          <label class="form-label" for="description">Mô tả / Tóm tắt</label>
          <textarea id="description" name="description" class="form-control"
            placeholder="Mô tả ngắn về nội dung sách..."><%= book.description || '' %></textarea>
        </div>
      </div>

      <div style="display:flex; gap:12px; margin-top:24px; padding-top:20px; border-top:1px solid var(--border)">
        <button type="submit" class="btn btn-primary">
          <%= isEdit ? '💾 Lưu thay đổi' : '➕ Thêm sách' %>
        </button>
        <a href="/books" class="btn btn-ghost">Hủy</a>
      </div>
    </form>
  </div>
</div>
