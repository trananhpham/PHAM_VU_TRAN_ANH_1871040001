<% layout('layout/main') %>
<!-- Page Header -->
<div class="page-header">
  <div>
    <h1>📚 Quản lý Sách</h1>
    <p>Tổng cộng <strong><%= total %></strong> đầu sách trong thư viện</p>
  </div>
  <a href="/books/new" class="btn btn-primary">➕ Thêm sách mới</a>
</div>

<!-- Search & Filter -->
<div class="card mb-4">
  <div class="card-body">
    <form action="/books" method="GET">
      <div class="search-bar">
        <div class="search-input-wrap" style="flex:2">
          <span class="search-icon">🔍</span>
          <input type="text" name="search" value="<%= search %>" placeholder="Tìm tên sách, tác giả, ISBN..." class="form-control" id="search-input">
        </div>
        <select name="category" class="form-control" id="category-filter" style="max-width:200px">
          <option value="">-- Tất cả thể loại --</option>
          <% categories.forEach(cat => { %>
            <option value="<%= cat %>" <%= category === cat ? 'selected' : '' %>><%= cat %></option>
          <% }) %>
        </select>
        <button type="submit" class="btn btn-primary">Tìm kiếm</button>
        <% if (search || category) { %>
          <a href="/books" class="btn btn-ghost">✕ Xóa lọc</a>
        <% } %>
      </div>
    </form>
  </div>
</div>

<!-- Books Table -->
<div class="card">
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>ID</th>
          <th>Tên sách</th>
          <th>Tác giả</th>
          <th>Thể loại</th>
          <th>ISBN</th>
          <th style="text-align:center">Tổng</th>
          <th style="text-align:center">Còn lại</th>
          <th style="text-align:center">Thao tác</th>
        </tr>
      </thead>
      <tbody>
        <% if (books.length === 0) { %>
          <tr>
            <td colspan="8">
              <div class="empty-state">
                <div class="empty-icon">📭</div>
                <h3>Không tìm thấy sách</h3>
                <p><% if (search || category) { %>Thử thay đổi từ khóa tìm kiếm<% } else { %>Hãy thêm sách đầu tiên vào thư viện<% } %></p>
                <a href="/books/new" class="btn btn-primary">➕ Thêm sách mới</a>
              </div>
            </td>
          </tr>
        <% } else { %>
          <% books.forEach(book => { %>
            <tr>
              <td style="color:var(--text-faint); font-size:0.8rem">#<%= book.id %></td>
              <td>
                <a href="/books/<%= book.id %>" style="font-weight:600; color:var(--text)">
                  <%= book.title %>
                </a>
                <% if (book.published_year) { %>
                  <div style="font-size:0.75rem; color:var(--text-faint)"><%= book.published_year %></div>
                <% } %>
              </td>
              <td style="color:var(--text-muted)"><%= book.author %></td>
              <td><span class="badge badge-info"><%= book.category %></span></td>
              <td style="font-size:0.8rem; color:var(--text-faint)"><%= book.isbn || '—' %></td>
              <td style="text-align:center; font-weight:600"><%= book.quantity %></td>
              <td style="text-align:center">
                <span class="available-count <%= book.available === 0 ? 'zero' : book.available <= 2 ? 'low' : 'ok' %>">
                  <%= book.available === 0 ? '🔴' : book.available <= 2 ? '🟡' : '🟢' %>
                  <%= book.available %>
                </span>
              </td>
              <td>
                <div style="display:flex; gap:6px; justify-content:center">
                  <a href="/books/<%= book.id %>" class="btn btn-ghost btn-sm btn-icon" title="Xem chi tiết">👁️</a>
                  <a href="/books/<%= book.id %>/edit" class="btn btn-ghost btn-sm btn-icon" title="Sửa">✏️</a>
                  <form action="/books/<%= book.id %>?_method=DELETE" method="POST" style="display:inline">
                    <input type="hidden" name="_method" value="DELETE">
                    <button type="submit" class="btn btn-danger btn-sm btn-icon" title="Xóa"
                      data-confirm="Bạn có chắc muốn xóa sách '<%= book.title %>'?">🗑️</button>
                  </form>
                </div>
              </td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>

  <!-- Pagination -->
  <% if (totalPages > 1) { %>
    <div class="pagination">
      <a href="/books?search=<%= search %>&category=<%= category %>&page=<%= Math.max(1, page-1) %>"
         class="page-btn <%= page <= 1 ? 'disabled' : '' %>">‹</a>
      <% for(let i = 1; i <= totalPages; i++) { %>
        <a href="/books?search=<%= search %>&category=<%= category %>&page=<%= i %>"
           class="page-btn <%= i === page ? 'active' : '' %>"><%= i %></a>
      <% } %>
      <a href="/books?search=<%= search %>&category=<%= category %>&page=<%= Math.min(totalPages, page+1) %>"
         class="page-btn <%= page >= totalPages ? 'disabled' : '' %>">›</a>
    </div>
  <% } %>
</div>
